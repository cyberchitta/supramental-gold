<%
// Compact CyberChitta chrome (used on sub-sites; sits above the sub-site bar).
// Attributes (all optional):
//   logoUrl  — logo image URL (defaults to canonical CC mark)
const _logoUrl = (typeof logoUrl !== 'undefined' && logoUrl)
  || 'https://www.cyberchitta.cc/assets/images/shared/cc-260508.svg';
%>
<div class="cc-chrome">
  <a href="https://www.cyberchitta.cc/" class="cc-logo">
    <img src="<%= _logoUrl %>" alt="CyberChitta" decoding="async" width="32" height="32">
  </a>
  <a href="https://www.cyberchitta.cc/" class="logo-text font-typewriter no-underline">CyberChitta</a>
</div>
