{
  "name": "@cyberchitta/supramental-gold",
  "version": "0.3.4",
  "description": "CyberChitta design system — tokens, primitives, and Eleventy plugin shared across cyberchitta.cc and its sub-sites.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./eleventy/index.js",
    "./package.json": "./package.json",
    "./eleventy": "./eleventy/index.js",
    "./eleventy/renderer": "./eleventy/custom-element-renderer.js",
    "./eleventy/section-title-transform": "./eleventy/section-title-transform.js",
    "./eleventy/helpers": "./eleventy/helpers.js",
    "./eleventy/build-helpers": "./eleventy/build-helpers.js",
    "./eleventy/markdown-library": "./eleventy/markdown-library.js",
    "./tokens.css": "./colors-and-type.css",
    "./ui-kit.css": "./ui-kit.css",
    "./tailwind.css": "./tailwind.css",
    "./dist/styles.css": "./dist/styles.css",
    "./assets/*": "./assets/*",
    "./primitives/*": "./eleventy/primitives/*"
  },
  "files": [
    "eleventy",
    "assets",
    "colors-and-type.css",
    "ui-kit.css",
    "tailwind.css",
    "dist",
    "NOTES.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:css": "bun x @tailwindcss/cli -i tailwind.css -o dist/styles.css --minify",
    "watch:css": "bun x @tailwindcss/cli -i tailwind.css -o dist/styles.css --watch"
  },
  "dependencies": {
    "ejs": "^5.0.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-external-links": "^0.0.6",
    "markdown-it-footnote": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.4"
  }
}
